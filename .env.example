# Application
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# Database (Postgres recommended; SQLite works for quick local demos)
# DATABASE_URL=sqlite:///./dev.db
DATABASE_URL=postgresql+psycopg2://resume:resume@localhost:5432/resume_reviewer

# LLM — ollama | openai | anthropic
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
PROMPT_VERSION=v1

# Storage — local | s3
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Frontend (browser uses same-origin /api via Next rewrite)
API_PROXY_TARGET=http://localhost:8000
